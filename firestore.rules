rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return request.auth.token.email_verified == true;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function hasRole(role) {
      return isSignedIn() && isEmailVerified() && getUserData().role == role;
    }

    function isAdmin() {
      return hasRole('Admin');
    }

    function isDispatcher() {
      return hasRole('Dispatcher');
    }

    function isDriver() {
      return hasRole('Driver');
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- User Validation ---
    function isValidUser(data) {
      return data.uid == request.auth.uid 
        && data.email is string 
        && data.role in ['Admin', 'Dispatcher', 'Driver']
        && data.keys().hasAll(['uid', 'email', 'role'])
        && data.keys().size() <= 6;
    }

    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidUser(incoming()) && (incoming().role != 'Admin' || request.auth.token.email == 'onwukachiomaaniekwe@gmail.com');
      allow update: if isSignedIn() && userId == request.auth.uid && isValidUser(incoming()) && incoming().role == existing().role;
    }

    // --- Order Validation ---
    function isValidOrder(data) {
      return data.id is string
        && data.customerName is string && data.customerName.size() <= 100
        && data.status in ['Pending', 'In Transit', 'Delivered', 'Cancelled']
        && data.keys().hasAll(['id', 'customerName', 'status', 'origin', 'destination'])
        && data.origin.lat is number && data.origin.lng is number
        && data.destination.lat is number && data.destination.lng is number;
    }

    match /orders/{orderId} {
      allow read: if isSignedIn();
      allow create: if (isAdmin() || isDispatcher()) && isValidOrder(incoming()) && isValidId(orderId);
      allow update: if (isAdmin() || isDispatcher() || (isDriver() && incoming().driverId == request.auth.uid)) 
        && isValidOrder(incoming()) 
        && (
          (isAdmin() || isDispatcher()) || 
          (isDriver() && incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt']))
        );
      allow delete: if isAdmin();
    }

    // --- Driver Validation ---
    function isValidDriver(data) {
      return data.id is string && data.name is string 
        && data.status in ['Active', 'Offline', 'On Break']
        && data.keys().hasAll(['id', 'name', 'status']);
    }

    match /drivers/{driverId} {
      allow read: if isSignedIn();
      allow create, update: if (isAdmin() || isDispatcher() || (isSignedIn() && driverId == request.auth.uid)) && isValidDriver(incoming());
    }

    // --- Vehicle Validation ---
    match /vehicles/{vehicleId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || isDispatcher();
    }

    // --- Route Validation ---
    match /routes/{routeId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || isDispatcher();
    }
  }
}
